default_platform(:ios)

PROJECT        = "Spinefin.xcodeproj"
SCHEME         = "Spinefin"
APP_IDENTIFIER = "com.spinefin.app"
TEAM_ID        = "TUA96GSK9L"
PROFILE_NAME   = "match AppStore #{APP_IDENTIFIER}"

platform :ios do
  # The .xcodeproj is generated by XcodeGen (and gitignored), so it may not
  # exist on a fresh CI checkout. Regenerate it from project.yml before any build.
  before_all do
    Dir.chdir("..") { sh("xcodegen", "generate") }
  end

  # Builds the App Store Connect API key from the ASC_* env vars (fastlane/.env).
  private_lane :asc_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_CONTENT"),
      is_key_content_base64: true,
    )
  end

  desc "Create/fetch signing certs via the API key (no Apple ID login)"
  lane :certs do
    match(
      type: "appstore",
      app_identifier: APP_IDENTIFIER,
      api_key: asc_api_key,
      readonly: false,
    )
  end

  desc "Build and upload a new build to TestFlight"
  lane :beta do
    # On CI, create a dedicated unlocked keychain for the signing identity.
    # Without this, codesign imports into the login keychain and hangs forever on
    # a keychain-access prompt that never appears on a headless runner.
    setup_ci if is_ci

    api_key = asc_api_key

    # Fetch the distribution cert + provisioning profile. Locally (first run) this
    # creates them in the certs repo; on CI it's read-only.
    match(
      type: "appstore",
      app_identifier: APP_IDENTIFIER,
      api_key: api_key,
      readonly: is_ci,
    )

    # Build numbers must be unique per app — take the highest on TestFlight + 1.
    next_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      initial_build_number: 0,
    ) + 1

    # XcodeGen emits Automatic signing; switch the generated project to the
    # match-managed profile so the archive signs with the distribution cert.
    update_code_signing_settings(
      path: PROJECT,
      use_automatic_signing: false,
      team_id: TEAM_ID,
      bundle_identifier: APP_IDENTIFIER,
      code_sign_identity: "Apple Distribution",
      profile_name: PROFILE_NAME,
    )

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      output_directory: "build",
      xcargs: "CURRENT_PROJECT_VERSION=#{next_build}",
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: { APP_IDENTIFIER => PROFILE_NAME },
      },
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
