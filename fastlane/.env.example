# Copy to fastlane/.env and fill in. NEVER commit the real .env (it's gitignored).
# Load happens automatically when you run `fastlane beta`.

# --- App Store Connect API key ---------------------------------------------
# App Store Connect → Users and Access → Integrations → App Store Connect API.
# Create a key with the "App Manager" role, download the .p8 ONCE.
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# base64 of the .p8 file:  base64 -i AuthKey_XXXXXXXXXX.p8 | pbcopy
ASC_KEY_CONTENT=

# --- fastlane match ---------------------------------------------------------
# A SEPARATE private git repo that stores the encrypted certs/profiles.
MATCH_GIT_URL=git@github.com:saigorupati/spinefin-certs.git
# Passphrase that encrypts the match repo (pick one, keep it safe).
MATCH_PASSWORD=

# CI ONLY — HTTPS auth for the certs repo, base64 of "username:personal_access_token":
#   echo -n "saigorupati:ghp_xxx" | base64
# MATCH_GIT_BASIC_AUTHORIZATION=
